{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Dev: Full Stack",
      "type": "shell",
      "command": "npm run dev",
      "group": { "kind": "build", "isDefault": true },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Dev: Frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/apps/frontend" },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Dev: Backend",
      "type": "shell",
      "command": "npm run start:dev",
      "options": { "cwd": "${workspaceFolder}/apps/backend" },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Build: Frontend",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}/apps/frontend" },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Build: Backend",
      "type": "shell",
      "command": "npm run build",
      "options": { "cwd": "${workspaceFolder}/apps/backend" },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Test: Frontend",
      "type": "shell",
      "command": "npm run test",
      "options": { "cwd": "${workspaceFolder}/apps/frontend" },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Test: Backend",
      "type": "shell",
      "command": "npm run test",
      "options": { "cwd": "${workspaceFolder}/apps/backend" },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Lint: All",
      "type": "shell",
      "command": "npm run lint",
      "problemMatcher": ["$eslint-stylish"]
    },
    {
      "label": "Docker: Up",
      "type": "shell",
      "command": "docker-compose up -d",
      "problemMatcher": []
    },
    {
      "label": "Docker: Down",
      "type": "shell",
      "command": "docker-compose down",
      "problemMatcher": []
    },
    {
      "label": "DB: Generate Prisma",
      "type": "shell",
      "command": "npx prisma generate",
      "options": { "cwd": "${workspaceFolder}/apps/backend" },
      "problemMatcher": []
    },
    {
      "label": "DB: Migrate",
      "type": "shell",
      "command": "npx prisma migrate dev",
      "options": { "cwd": "${workspaceFolder}/apps/backend" },
      "problemMatcher": []
    }
  ]
}
