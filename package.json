{
  "name": "ai-digital-twin-platform",
  "version": "0.1.0",
  "private": true,
  "description": "AI Digital Twin Platform - Enterprise-grade monorepo",
  "author": "AI Digital Twin Team",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm run --prefix apps/frontend dev",
    "dev:backend": "npm run --prefix apps/backend start:dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "npm run --prefix apps/frontend build",
    "build:backend": "npm run --prefix apps/backend build",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "npm run --prefix apps/frontend lint",
    "lint:backend": "npm run --prefix apps/backend lint",
    "lint:fix": "npm run lint:fix:frontend && npm run lint:fix:backend",
    "lint:fix:frontend": "npm run --prefix apps/frontend lint:fix",
    "lint:fix:backend": "npm run --prefix apps/backend lint:fix",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "npm run --prefix apps/frontend test",
    "test:backend": "npm run --prefix apps/backend test",
    "test:e2e": "npm run --prefix apps/frontend test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,scss,html,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,scss,html,yaml,yml}\"",
    "typecheck": "npm run typecheck:frontend && npm run typecheck:backend",
    "typecheck:frontend": "npm run --prefix apps/frontend typecheck",
    "typecheck:backend": "npm run --prefix apps/backend typecheck",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build",
    "db:generate": "npm run --prefix apps/backend db:generate",
    "db:migrate": "npm run --prefix apps/backend db:migrate",
    "db:push": "npm run --prefix apps/backend db:push",
    "db:seed": "npm run --prefix apps/backend db:seed",
    "db:studio": "npm run --prefix apps/backend db:studio",
    "prepare": "npx husky || true",
    "precommit": "lint-staged",
    "prepush": "node scripts/utilities/pre-push.js",
    "setup": "bash scripts/setup/setup.sh",
    "project:status": "npx tsx scripts/project-manager/index.ts status",
    "project:update": "npx tsx scripts/project-manager/index.ts update",
    "project:next": "npx tsx scripts/project-manager/index.ts next",
    "project:complete": "npx tsx scripts/project-manager/index.ts complete",
    "project:validate": "npx tsx scripts/project-manager/index.ts validate",
    "project:report": "npx tsx scripts/project-manager/index.ts report",
    "project:timeline": "npx tsx scripts/project-manager/index.ts timeline",
    "project:help": "npx tsx scripts/project-manager/index.ts help"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "concurrently": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.4.2"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "dompurify": "^3.2.4",
    "multer": "^1.4.5-lts.1",
    "@hono/node-server": "^1.19.13"
  }
}
