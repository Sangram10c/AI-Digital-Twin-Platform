{
  "name": "ai-digital-twin-platform",
  "version": "0.1.0",
  "private": true,
  "description": "AI Digital Twin Platform - Enterprise-grade monorepo",
  "author": "AI Digital Twin Team",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "npm run --prefix frontend dev",
    "dev:backend": "npm run --prefix backend start:dev",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "npm run --prefix frontend build",
    "build:backend": "npm run --prefix backend build",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "npm run --prefix frontend lint",
    "lint:backend": "npm run --prefix backend lint",
    "lint:fix": "npm run lint:fix:frontend && npm run lint:fix:backend",
    "lint:fix:frontend": "npm run --prefix frontend lint:fix",
    "lint:fix:backend": "npm run --prefix backend lint:fix",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "npm run --prefix frontend test",
    "test:backend": "npm run --prefix backend test",
    "test:e2e": "npm run --prefix frontend test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,scss,html,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,scss,html,yaml,yml}\"",
    "typecheck": "npm run typecheck:frontend && npm run typecheck:backend",
    "typecheck:frontend": "npm run --prefix frontend typecheck",
    "typecheck:backend": "npm run --prefix backend typecheck",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build",
    "db:generate": "npm run --prefix backend db:generate",
    "db:migrate": "npm run --prefix backend db:migrate",
    "db:push": "npm run --prefix backend db:push",
    "db:seed": "npm run --prefix backend db:seed",
    "db:studio": "npm run --prefix backend db:studio",
    "prepare": "husky",
    "precommit": "lint-staged",
    "prepush": "node scripts/pre-push.js",
    "setup": "bash scripts/setup.sh"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^19.6.0",
    "concurrently": "^10.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.4.2"
  }
}
