model DigestChecksum {
  id String @id @default(uuid()) @db.Uuid

  workspaceId  String     @map("workspace_id") @db.Uuid
  repositoryId String     @map("repository_id") @db.Uuid
  digestKind   DigestKind @map("digest_kind")
  digestKey    String     @map("digest_key") @db.VarChar(512)
  checksum     String     @db.VarChar(64)
  version      Int        @default(1)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace  Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  repository Repository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([repositoryId, digestKind, digestKey], map: "uq_digest_checksums_repo_kind_key")
  @@index([workspaceId], map: "idx_digest_checksums_workspace_id")
  @@map("digest_checksums")
}

model AIAnalysis {
  id String @id @default(uuid()) @db.Uuid

  workspaceId  String            @map("workspace_id") @db.Uuid
  repositoryId String            @map("repository_id") @db.Uuid
  digestKind   DigestKind        @map("digest_kind")
  mode         AIExtractionMode  @default(LIGHT)
  status       AIAnalysisStatus  @default(PENDING)

  repositoryDigestId    String? @map("repository_digest_id") @db.Uuid
  moduleDigestId        String? @map("module_digest_id") @db.Uuid
  pullRequestDigestId   String? @map("pull_request_digest_id") @db.Uuid
  documentationDigestId String? @map("documentation_digest_id") @db.Uuid
  releaseDigestId       String? @map("release_digest_id") @db.Uuid

  provider      String? @db.VarChar(64)
  model         String? @db.VarChar(128)
  contentChecksum String? @map("content_checksum") @db.VarChar(64)
  result        Json?   @db.JsonB
  rawText       String? @map("raw_text") @db.Text
  latencyMs     Int?    @map("latency_ms")
  errorMessage  String? @map("error_message") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace             Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  repository            Repository            @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  repositoryDigest      RepositoryDigest?     @relation(fields: [repositoryDigestId], references: [id], onDelete: SetNull)
  moduleDigest          ModuleDigest?         @relation(fields: [moduleDigestId], references: [id], onDelete: SetNull)
  pullRequestDigest     PullRequestDigest?    @relation(fields: [pullRequestDigestId], references: [id], onDelete: SetNull)
  documentationDigest   DocumentationDigest?  @relation(fields: [documentationDigestId], references: [id], onDelete: SetNull)
  releaseDigest         ReleaseDigest?        @relation(fields: [releaseDigestId], references: [id], onDelete: SetNull)
  providerExecutions    ProviderExecution[]
  providerFailures      ProviderFailure[]

  @@index([workspaceId], map: "idx_ai_analyses_workspace_id")
  @@index([repositoryId], map: "idx_ai_analyses_repository_id")
  @@index([status], map: "idx_ai_analyses_status")
  @@index([digestKind], map: "idx_ai_analyses_digest_kind")
  @@map("ai_analyses")
}

model ProviderExecution {
  id String @id @default(uuid()) @db.Uuid

  workspaceId  String  @map("workspace_id") @db.Uuid
  aiAnalysisId String? @map("ai_analysis_id") @db.Uuid

  provider   String  @db.VarChar(64)
  model      String? @db.VarChar(128)
  success    Boolean @default(false)
  latencyMs  Int?    @map("latency_ms")
  tokenUsage Int?    @map("token_usage")
  requestMeta Json?  @map("request_meta") @db.JsonB
  responseMeta Json? @map("response_meta") @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  aiAnalysis AIAnalysis? @relation(fields: [aiAnalysisId], references: [id], onDelete: SetNull)

  @@index([workspaceId], map: "idx_provider_executions_workspace_id")
  @@index([provider], map: "idx_provider_executions_provider")
  @@map("provider_executions")
}

model ProviderFailure {
  id String @id @default(uuid()) @db.Uuid

  workspaceId  String  @map("workspace_id") @db.Uuid
  aiAnalysisId String? @map("ai_analysis_id") @db.Uuid

  provider     String @db.VarChar(64)
  errorCode    String? @map("error_code") @db.VarChar(64)
  errorMessage String @map("error_message") @db.Text
  retriable    Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  aiAnalysis AIAnalysis? @relation(fields: [aiAnalysisId], references: [id], onDelete: SetNull)

  @@index([workspaceId], map: "idx_provider_failures_workspace_id")
  @@index([provider], map: "idx_provider_failures_provider")
  @@map("provider_failures")
}

model AIExecutionLog {
  id String @id @default(uuid()) @db.Uuid

  workspaceId  String           @map("workspace_id") @db.Uuid
  repositoryId String?          @map("repository_id") @db.Uuid
  mode         AIExtractionMode @default(LIGHT)

  apiCalls          Int   @default(0) @map("api_calls")
  tokenUsage        Int   @default(0) @map("token_usage")
  estimatedCostUsd  Float @default(0) @map("estimated_cost_usd")
  failedProviders   Int   @default(0) @map("failed_providers")
  fallbackCount     Int   @default(0) @map("fallback_count")
  digestCacheHits   Int   @default(0) @map("digest_cache_hits")
  heuristicCoverage Float @default(0) @map("heuristic_coverage")
  averageAiTimeMs   Int   @default(0) @map("average_ai_time_ms")
  metadata          Json? @db.JsonB

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  repository Repository? @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@index([workspaceId], map: "idx_ai_execution_logs_workspace_id")
  @@index([repositoryId], map: "idx_ai_execution_logs_repository_id")
  @@map("ai_execution_logs")
}
