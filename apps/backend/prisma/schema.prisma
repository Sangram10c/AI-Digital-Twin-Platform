model ReleaseDigest {
  id String @id @default(uuid()) @db.Uuid

  workspaceId  String @map("workspace_id") @db.Uuid
  repositoryId String @map("repository_id") @db.Uuid

  releaseKey      String @map("release_key") @db.VarChar(255)
  title           String @db.VarChar(512)
